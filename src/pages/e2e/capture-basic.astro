<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Basic Capture Test</title>
		<script is:inline src="/attach.js"></script>
		<style>
			:root {
				color-scheme: light dark;
				view-transition-name: none;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				padding: 2rem;
				font-family: system-ui, sans-serif;
			}

			h1 {
				margin: 0;
				font-size: 2rem;
			}

			button {
				margin-top: 0.5rem;
				padding: 0.5rem 1rem;
				font-size: 1rem;
				cursor: pointer;
			}

			/* --- shared base styles --- */

			#hero {
				padding: 2rem;
				background: light-dark(#dbeafe, #1e3a8a);
				border-radius: 0.5rem;
			}

			#element-a {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#fce7f3, #831843);
				border-radius: 0.5rem;
				/* no view-transition-name by default */
			}

			#element-b {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#e0f2fe, #0c4a6e);
				border-radius: 0.5rem;
			}

			/* --- none: nothing to capture because no view transition names are defined --- */

			html:active-view-transition-type(none) {
				view-transition-name: none;
			}

			/* --- root: captures group root with old and new element --- */

			html:active-view-transition-type(root) {
				view-transition-name: root;
			}

			/* --- old-only: captures group old-only, which has an old but no new element --- */

			html:active-view-transition-type(old-only) {
				body.old #element-a {
					view-transition-name: old-only;
				}
			}

			/* --- new-only: captures group new-only, which has a new but no old element --- */

			html:active-view-transition-type(new-only) {
				body.new #element-b {
					view-transition-name: new-only;
				}
			}

			/* --- hidden: captures group hidden, where the new image is hidden --- */

			html:active-view-transition-type(hidden) {
				#element-a {
					view-transition-name: hidden;
				}
				body.new #element-a {
					display: none;
				}
			}

			/* --- more-hidden: more ways to hide elements --- */

			html:active-view-transition-type(more-hidden) {
				body.old #element-a {
					view-transition-name: old-a;
					p {
						view-transition-name: old-a;
					}
					@supports (view-transition-scope: all) {
						view-transition-scope: all;
					}
					@supports not (view-transition-scope: all) {
						display: none;
					}
				}
				body.old #element-b {
					view-transition-name: old-b-1;
					p {
						view-transition-name: old-b-2;
					}
					content-visibility: hidden;
				}
				body.old #trigger-more-hidden {
					display: contents;
					span {
						view-transition-name: old-hidden; /* not hidden */
					}
				}
				body.new #element-a {
					view-transition-name: new-a;
					p {
						view-transition-name: new-a;
					}
					@supports (view-transition-scope: all) {
						view-transition-scope: all;
					}
					@supports not (view-transition-scope: all) {
						display: none;
					}
				}
				body.new #element-b {
					view-transition-name: new-b;
					display: contents;
				}
				body.new #trigger-hidden {
					view-transition-name: new-hidden;
					span {
						view-transition-name: new-hidden;
					}
				}
			}

			/* --- different: different elements with same name --- */

			html:active-view-transition-type(different) {
				body.old #element-a {
					view-transition-name: shared-element;
				}
				body.new #element-b {
					view-transition-name: shared-element;
				}
			}

			/* --- test-1-5: pseudo-element ::before with view-transition-name --- */

			html:active-view-transition-type(test-1-5) {
				body.old #element-a::before {
					content: 'Before';
					view-transition-name: before-pseudo;
				}
				body.new #element-b:before {
					view-transition-name: before-pseudo;
				}
			}

			/* --- test-1-6: pseudo-element ::before and ::after with view-transition-name --- */

			html:active-view-transition-type(test-1-6) {
				#element-b::after {
					content: 'After';
					view-transition-name: after-pseudo;
				}
				#element-b::before {
					content: 'Before';
					view-transition-name: before-pseudo;
				}
			}

			/* --- test-1-7: duplicate view-transition-name detection --- */

			html:active-view-transition-type(test-1-7) {
				#hero,
				#element-a,
				#element-b {
					view-transition-name: duplicate;
				}
			}

			/* --- test-1-8: CSS escape sequences in view-transition-name --- */

			html:active-view-transition-type(test-1-8) {
				#element-a {
					view-transition-name: \!important;
				}
			}
		</style>
	</head>
	<body>
		<div id="hero">
			<h1>Hero Element</h1>
			<button id="trigger-none">none</button>
			<button id="trigger-root">root</button>
			<button id="trigger-old-only">old-only</button>
			<button id="trigger-hidden"><span>hidden</span></button>
			<button id="trigger-more-hidden"><span>more-hidden</span></button>
			<button id="trigger-new-only">new-only</button>
			<button id="trigger-different">different</button>
			<button id="trigger-test-1-5">Test 1.5</button>
			<button id="trigger-test-1-6">Test 1.6</button>
			<button id="trigger-test-1-7">Test 1.7</button>
			<button id="trigger-test-1-8">Test 1.8</button>
		</div>

		<div id="element-a" data-test-element="a">
			<p>Element A</p>
		</div>

		<div id="element-b" data-test-element="b">
			<p>Element B</p>
		</div>

		<script>
			import { mayStartViewTransition } from '@vtbag/utensil-drawer/may-start-view-transition';

			function triggerTransition(types: string[]) {
				const classList = document.body.classList;
				classList.toggle('new', false);
				classList.toggle('old', true);
				return mayStartViewTransition(
					{
						update: () => {
							classList.toggle('old', false);
							classList.toggle('new', true);
						},
						types: types,
					},
					{ useTypesPolyfill: 'always' }
				);
			}
			document
				.getElementById('trigger-none')
				?.addEventListener('click', () => triggerTransition(['none']));
			document
				.getElementById('trigger-root')
				?.addEventListener('click', () => triggerTransition(['root']));
			document
				.getElementById('trigger-old-only')
				?.addEventListener('click', () => triggerTransition(['old-only']));
			document
				.getElementById('trigger-new-only')
				?.addEventListener('click', () => triggerTransition(['new-only']));
			document
				.getElementById('trigger-hidden')
				?.addEventListener('click', () => triggerTransition(['hidden']));
			document.getElementById('trigger-more-hidden')?.addEventListener('click', (e) => {
				(document.querySelector('#trigger-hidden ') as HTMLElement).setAttribute('hidden', '');
				triggerTransition(['more-hidden']).ready.then(() => {
					(document.querySelector('#trigger-hidden ') as HTMLElement).removeAttribute('hidden');
				});
			});
			document
				.getElementById('trigger-different')
				?.addEventListener('click', () => triggerTransition(['different']));
			document
				.getElementById('trigger-test-1-5')
				?.addEventListener('click', () => triggerTransition(['test-1-5']));
			document
				.getElementById('trigger-test-1-6')
				?.addEventListener('click', () => triggerTransition(['test-1-6']));
			document
				.getElementById('trigger-test-1-7')
				?.addEventListener('click', () => triggerTransition(['test-1-7']));
			document
				.getElementById('trigger-test-1-8')
				?.addEventListener('click', () => triggerTransition(['test-1-8']));
		</script>
	</body>
</html>
