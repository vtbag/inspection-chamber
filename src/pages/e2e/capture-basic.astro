---
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Basic Capture Test</title>
		<script is:inline src="/attach.js"></script>
		<style>
			:root {
				color-scheme: light dark;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				padding: 2rem;
				font-family: system-ui, sans-serif;
			}

			h1 {
				margin: 0;
				font-size: 2rem;
			}

			button {
				margin-top: 0.5rem;
				padding: 0.5rem 1rem;
				font-size: 1rem;
				cursor: pointer;
			}

			/* --- shared base styles --- */

			#hero {
				padding: 2rem;
				background: light-dark(#dbeafe, #1e3a8a);
				border-radius: 0.5rem;
				view-transition-name: hero;
			}

			#old-only {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#fee2e2, #7f1d1d);
				border-radius: 0.5rem;
				/* no view-transition-name by default */
			}

			#new-only {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#fef3c7, #92400e);
				border-radius: 0.5rem;
				/* no view-transition-name by default */
			}

			#persistent {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#e0e7ff, #312e81);
				border-radius: 0.5rem;
				/* no view-transition-name by default */
			}

			#elem-a {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#fce7f3, #831843);
				border-radius: 0.5rem;
				/* no view-transition-name by default */
			}

			#elem-b {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#e0f2fe, #0c4a6e);
				border-radius: 0.5rem;
				/* no view-transition-name by default */
			}

			#pseudo-test {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#f3e8ff, #4c1d95);
				border-radius: 0.5rem;
				/* no view-transition-name by default */
			}

			#duplicate-a,
			#duplicate-b {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#fecdd3, #7f2d2d);
				border-radius: 0.5rem;
				/* no view-transition-name by default */
			}

			#escaped-name {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#e0e7ff, #312e81);
				border-radius: 0.5rem;
				/* no view-transition-name by default */
			}

			/* --- test-1-1: basic capture with hero --- */

			html:active-view-transition-type(test-1-1) {
				.state-b #hero {
					background: light-dark(#dcfce7, #14532d);
				}
				.state-b h1 {
					font-size: 3rem;
				}
			}

			/* --- test-1-2: old-only element (removed in new state) --- */

			html:active-view-transition-type(test-1-2) {
				#old-only {
					view-transition-name: old-only-element;
				}
				.state-b #hero {
					background: light-dark(#dcfce7, #14532d);
				}
				.state-b #old-only {
					display: none;
				}
			}

			/* --- test-1-3: new-only element (created in new state) --- */

			html:active-view-transition-type(test-1-3) {
				#new-only {
					view-transition-name: new-only-element;
					display: none;
				}
				.state-b #hero {
					background: light-dark(#dcfce7, #14532d);
				}
				.state-b #new-only {
					display: block;
				}
			}

			/* --- test-1-4: same element old and new (style changes only) --- */

			html:active-view-transition-type(test-1-4) {
				#persistent {
					view-transition-name: persistent-element;
				}
				.state-b #persistent {
					background: light-dark(#fef9c3, #854d0e);
					padding: 2rem;
					font-size: 1.5rem;
				}
			}

			/* --- test-1-5: different elements with same name --- */

			html:active-view-transition-type(test-1-5) {
				/* elem-a has the name in old state, visible */
				#elem-a {
					view-transition-name: shared-element;
				}
				/* elem-b is hidden in old state */
				#elem-b {
					visibility: hidden;
				}
				/* in new state: elem-a hidden, elem-b visible with the name */
				.state-b #elem-a {
					display: contents;
				}
				.state-b #elem-b {
					view-transition-name: shared-element;
					visibility: visible;
				}
			}

			/* --- test-1-6: pseudo-element ::before with view-transition-name --- */

			html:active-view-transition-type(test-1-6) {
				#pseudo-test::before {
					content: 'Before';
					display: block;
					margin-bottom: 1rem;
					padding: 0.5rem;
					background: light-dark(#fbbf24, #f59e0b);
					border-radius: 0.25rem;
					view-transition-name: before-pseudo;
				}
				.state-b #pseudo-test {
					background: light-dark(#dbeafe, #1e3a8a);
				}
				.state-b #pseudo-test::before {
					background: light-dark(#c7d2fe, #818cf8);
				}
			}

			/* --- test-1-7: pseudo-element ::before and ::after with view-transition-name --- */

			html:active-view-transition-type(test-1-7) {
				#pseudo-test::before {
					content: 'Before';
					display: block;
					margin-bottom: 1rem;
					padding: 0.5rem;
					background: light-dark(#fbbf24, #f59e0b);
					border-radius: 0.25rem;
					view-transition-name: before-pseudo;
				}
				#pseudo-test::after {
					content: 'After';
					display: block;
					margin-top: 1rem;
					padding: 0.5rem;
					background: light-dark(#86efac, #22c55e);
					border-radius: 0.25rem;
					view-transition-name: after-pseudo;
				}
				.state-b #pseudo-test {
					background: light-dark(#dbeafe, #1e3a8a);
				}
				.state-b #pseudo-test::before {
					background: light-dark(#c7d2fe, #818cf8);
				}
				.state-b #pseudo-test::after {
					background: light-dark(#c7d2fe, #818cf8);
				}
			}

			/* --- test-1-8: duplicate view-transition-name detection --- */

			html:active-view-transition-type(test-1-8) {
				#duplicate-a,
				#duplicate-b {
					view-transition-name: duplicate;
				}
				.state-b #duplicate-a,
				.state-b #duplicate-b {
					background: light-dark(#fed7aa, #b45309);
				}
			}

			/* --- test-4-5: CSS escape sequences in view-transition-name --- */

			html:active-view-transition-type(test-4-5) {
				#escaped-name {
					view-transition-name: \!important;
				}
				.state-b #escaped-name {
					background: light-dark(#dcfce7, #14532d);
					padding: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<div id="hero">
			<h1>Hero Element</h1>
			<button id="trigger-test-1-1">Test 1.1</button>
			<button id="trigger-test-1-2">Test 1.2</button>
			<button id="trigger-test-1-3">Test 1.3</button>
			<button id="trigger-test-1-4">Test 1.4</button>
			<button id="trigger-test-1-5">Test 1.5</button>
		<button id="trigger-test-1-6">Test 1.6</button>
		<button id="trigger-test-1-7">Test 1.7</button>
		<button id="trigger-test-1-8">Test 1.8</button>
		<button id="trigger-test-4-5">Test 4.5</button>
	</div>

	<div id="old-only">
		<p>This element only exists in the old state</p>
	</div>

	<div id="new-only">
		<p>This element is created in the new state</p>
	</div>

	<div id="persistent" data-test-element="same">
		<p>Persistent Element (same across transition)</p>
	</div>

	<div id="elem-a" data-test-element="a">
		<p>Element A (old state only)</p>
	</div>

	<div id="elem-b" data-test-element="b">
		<p>Element B (new state only)</p>
	</div>

	<div id="pseudo-test">
		<p>Pseudo Element Test</p>
	</div>

	<div id="duplicate-a">
		<p>Duplicate A</p>
	</div>

	<div id="duplicate-b">
		<p>Duplicate B</p>
	</div>

	<div id="escaped-name">
		<p>Element with escaped characters in name (!important)</p>
	</div>

	<script>
		import { mayStartViewTransition } from '@vtbag/utensil-drawer/may-start-view-transition';

		function triggerTransition(type: string) {
			mayStartViewTransition(
				{ update: () => document.body.classList.toggle('state-b'), types: [type] },
				{ useTypesPolyfill: 'always' }
			);
		}
		document.getElementById('trigger-test-1-1')?.addEventListener('click', () => triggerTransition('test-1-1'));
		document.getElementById('trigger-test-1-2')?.addEventListener('click', () => triggerTransition('test-1-2'));
		document.getElementById('trigger-test-1-3')?.addEventListener('click', () => triggerTransition('test-1-3'));
		document.getElementById('trigger-test-1-4')?.addEventListener('click', () => triggerTransition('test-1-4'));
		document.getElementById('trigger-test-1-5')?.addEventListener('click', () => triggerTransition('test-1-5'));
		document.getElementById('trigger-test-1-6')?.addEventListener('click', () => triggerTransition('test-1-6'));
		document.getElementById('trigger-test-1-7')?.addEventListener('click', () => triggerTransition('test-1-7'));
		document.getElementById('trigger-test-1-8')?.addEventListener('click', () => triggerTransition('test-1-8'));
		document.getElementById('trigger-test-4-5')?.addEventListener('click', () => triggerTransition('test-4-5'));
	</script>
</body>
</html>
