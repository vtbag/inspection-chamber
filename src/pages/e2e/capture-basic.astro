<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Basic Capture Test</title>
		<script is:inline src="/attach.js"></script>
		<style>
			:root {
				color-scheme: light dark;
				view-transition-name: none;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				padding: 2rem;
				font-family: system-ui, sans-serif;
			}

			h1 {
				margin: 0;
				font-size: 2rem;
			}

			button {
				margin-top: 0.5rem;
				padding: 0.5rem 1rem;
				font-size: 1rem;
				cursor: pointer;
			}

			/* --- shared base styles --- */

			#hero {
				padding: 2rem;
				background: light-dark(#dbeafe, #1e3a8a);
				border-radius: 0.5rem;
			}

			#element-a {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#fce7f3, #831843);
				border-radius: 0.5rem;
				/* no view-transition-name by default */
			}

			#element-b {
				margin-top: 1rem;
				padding: 1rem;
				background: light-dark(#e0f2fe, #0c4a6e);
				border-radius: 0.5rem;
			}

			/* --- root: captures group root with old and new element --- */

			html:active-view-transition-type(root) {
				view-transition-name: root;
			}

			/* --- old-only: captures group old-only, which has an old but no new element --- */

			html:active-view-transition-type(old-only) {
				body.old #element-a {
					view-transition-name: old-only;
				}
			}

			/* --- test-1-3: captures group new-only, which has a new but no old element --- */

			html:active-view-transition-type(test-1-3) {
				body.new #element-b {
					view-transition-name: new-only;
				}
			}

			/* --- test-1-4: different elements with same name --- */

			html:active-view-transition-type(test-1-4) {
				body.old #element-a {
					view-transition-name: shared-element;
				}
				body.new #element-b {
					view-transition-name: shared-element;
				}
			}

			/* --- test-1-5: pseudo-element ::before with view-transition-name --- */

			html:active-view-transition-type(test-1-5) {
				body.old #element-a::before {
					content: 'Before';
					view-transition-name: before-pseudo;
				}
				body.new #element-b:before {
					view-transition-name: before-pseudo;
				}
			}

			/* --- test-1-6: pseudo-element ::before and ::after with view-transition-name --- */

			html:active-view-transition-type(test-1-6) {
				#element-b::after {
					content: 'After';
					view-transition-name: after-pseudo;
				}
				#element-b::before {
					content: 'Before';
					view-transition-name: before-pseudo;
				}
			}

			/* --- test-1-7: duplicate view-transition-name detection --- */

			html:active-view-transition-type(test-1-7) {
				#hero,
				#element-a,
				#element-b {
					view-transition-name: duplicate;
				}
			}

			/* --- test-1-8: CSS escape sequences in view-transition-name --- */

			html:active-view-transition-type(test-1-8) {
				#element-a {
					view-transition-name: \!important;
				}
			}
		</style>
	</head>
	<body>
		<div id="hero">
			<h1>Hero Element</h1>
			<button id="trigger-test-1-0">Test 1.0</button>
			<button id="trigger-root">Root</button>
			<button id="trigger-old-only">Old Only</button>
			<button id="trigger-test-1-3">Test 1.3</button>
			<button id="trigger-test-1-4">Test 1.4</button>
			<button id="trigger-test-1-5">Test 1.5</button>
			<button id="trigger-test-1-6">Test 1.6</button>
			<button id="trigger-test-1-7">Test 1.7</button>
			<button id="trigger-test-1-8">Test 1.8</button>
		</div>

		<div id="element-a" data-test-element="a">
			<p>Element A</p>
		</div>

		<div id="element-b" data-test-element="b">
			<p>Element B</p>
		</div>

		<script>
			import { mayStartViewTransition } from '@vtbag/utensil-drawer/may-start-view-transition';

			function triggerTransition(types: string[]) {
				const classList = document.body.classList;
				classList.toggle('new', false);
				classList.toggle('old', true);
				mayStartViewTransition(
					{
						update: () => {
							classList.toggle('old', false);
							classList.toggle('new', true);
						},
						types: types,
					},
					{ useTypesPolyfill: 'always' }
				);
			}
			document
				.getElementById('trigger-test-1-0')
				?.addEventListener('click', () => triggerTransition(['test-1-0']));
			document
				.getElementById('trigger-root')
				?.addEventListener('click', () => triggerTransition(['root']));
			document
				.getElementById('trigger-old-only')
				?.addEventListener('click', () => triggerTransition(['old-only']));
			document
				.getElementById('trigger-test-1-3')
				?.addEventListener('click', () => triggerTransition(['test-1-3']));
			document
				.getElementById('trigger-test-1-4')
				?.addEventListener('click', () => triggerTransition(['test-1-4']));
			document
				.getElementById('trigger-test-1-5')
				?.addEventListener('click', () => triggerTransition(['test-1-5']));
			document
				.getElementById('trigger-test-1-6')
				?.addEventListener('click', () => triggerTransition(['test-1-6']));
			document
				.getElementById('trigger-test-1-7')
				?.addEventListener('click', () => triggerTransition(['test-1-7']));
			document
				.getElementById('trigger-test-1-8')
				?.addEventListener('click', () => triggerTransition(['test-1-8']));
		</script>
	</body>
</html>
